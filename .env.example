# Copy this file to ".env" and fill in your real keys.

# OpenAI - used for Whisper ASR, Chat (function-calling), and TTS
OPENAI_API_KEY=sk-...

# Notion integration - create one at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# The Notion page ID (or database ID) under which new chat pages will be
# created. Share that page with your integration in the Notion UI.
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Models (override if you like)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_ASR_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Female voices: nova, shimmer, coral, sage
# Male voices:   echo, onyx, ash, fable
# Neutral:       alloy
OPENAI_TTS_VOICE=nova
